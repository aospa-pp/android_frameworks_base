<resources>

    <!-- Light / Regular style fonts -->
    <java-symbol type="string" name="config_lightFontFamily" />
    <java-symbol type="string" name="config_regularFontFamily" />

    <!-- Smart charging -->
    <java-symbol type="bool" name="config_smartChargingAvailable" />
    <java-symbol type="integer" name="config_smartChargingBatteryLevel" />
    <java-symbol type="integer" name="config_smartChargingBatteryResumeLevel" />
    <java-symbol type="string" name="config_smartChargingSysfsNode" />
    <java-symbol type="string" name="config_smartChargingSuspendValue" />
    <java-symbol type="string" name="config_smartChargingResumeValue" />

    <!-- Blur radius used by SystemUI -->
    <java-symbol type="dimen" name="min_window_blur_radius" />
    <java-symbol type="dimen" name="max_window_blur_radius" />

    <!-- Package Manager -->
    <java-symbol type="array" name="config_deviceDisabledComponents" />
    <java-symbol type="array" name="config_globallyDisabledComponents" />
    <java-symbol type="array" name="config_forceEnabledComponents" />

    <!-- DC Dimming -->
    <java-symbol type="string" name="config_deviceDcDimmingSysfsNode" />
    <java-symbol type="string" name="config_deviceDcDimmingEnableValue" />
    <java-symbol type="string" name="config_deviceDcDimmingDisableValue" />

    <!-- Alert Slider -->
    <java-symbol type="string" name="alert_slider_state_path" />
    <java-symbol type="string" name="alert_slider_uevent_match_path" />
    <java-symbol type="bool" name="config_hasAlertSlider" />

    <!-- Device key handlers -->
    <java-symbol type="array" name="config_deviceKeyHandlerLibs" />
    <java-symbol type="array" name="config_deviceKeyHandlerClasses" />

    <!-- Pocket Lock -->
    <java-symbol type="layout" name="pocket_lock_view" />

    <!-- Pocket Service -->
    <java-symbol type="bool" name="config_pocketModeSupported" />
    <java-symbol type="bool" name="config_pocketModeLightSensorSupported" />
    <java-symbol type="string" name="config_pocketJudgeVendorSensorName" />
    <java-symbol type="dimen" name="config_pocketJudgeVendorSensorValue" />

    <!-- Pocket bridge -->
    <java-symbol type="string" name="config_pocketBridgeSysfsInpocket" />

    <!-- Whether to use Richtap vibration -->
    <java-symbol type="bool" name="config_usesRichtapVibration" />

    <!-- Location indicator -->
    <java-symbol type="drawable" name="stat_sys_location" />

</resources>
